# Neon profile. Branching is an eval/replay accelerator, not a core dependency.
MEMPHANT_PROVIDER=neon
DATABASE_URL=postgresql://memphant_owner:REPLACE_ME@ep-example-123456.us-east-1.aws.neon.tech/memphant?sslmode=require
MEMPHANT_SCHEMA=memphant
MEMPHANT_PG_REGION=us-east-1
MEMPHANT_OBJECT_STORE=s3
MEMPHANT_OBJECT_STORE_BUCKET=customer-memphant-prod
MEMPHANT_OBJECT_STORE_REGION=us-east-1
MEMPHANT_OBJECT_VERSIONING_REQUIRED=true
MEMPHANT_PITR_WINDOW_DAYS=7
MEMPHANT_OBJECT_RETENTION_DAYS=14
MEMPHANT_NEON_BRANCH=memphant-prod
MEMPHANT_NEON_BRANCHING_FOR_EVALS=true


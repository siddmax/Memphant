{
  "$defs": {
    "ActorId": {
      "format": "uuid",
      "type": "string"
    },
    "EpisodeId": {
      "format": "uuid",
      "type": "string"
    },
    "MemoryKind": {
      "enum": [
        "episodic",
        "semantic",
        "procedural",
        "belief",
        "resource"
      ],
      "type": "string"
    },
    "ProcedureTraceFact": {
      "properties": {
        "safety_status": {
          "type": "string"
        },
        "signal_kind": {
          "type": "string"
        },
        "unit_id": {
          "$ref": "#/$defs/UnitId"
        },
        "validation_state": {
          "type": "string"
        }
      },
      "required": [
        "unit_id",
        "validation_state",
        "signal_kind",
        "safety_status"
      ],
      "type": "object"
    },
    "RecallCandidateTrace": {
      "properties": {
        "channel": {
          "$ref": "#/$defs/RecallChannel"
        },
        "channel_rank": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "channel_score": {
          "format": "float",
          "type": "number"
        },
        "decay_retrievability": {
          "default": 0.0,
          "format": "float",
          "type": "number"
        },
        "discard_reason": {
          "anyOf": [
            {
              "$ref": "#/$defs/RecallDropReason"
            },
            {
              "type": "null"
            }
          ]
        },
        "dsr_difficulty": {
          "default": null,
          "format": "float",
          "type": [
            "number",
            "null"
          ]
        },
        "dsr_reinforcement_count": {
          "default": 0,
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "dsr_stability_days": {
          "default": null,
          "format": "float",
          "type": [
            "number",
            "null"
          ]
        },
        "fused_rank": {
          "format": "uint",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "fused_score": {
          "format": "float",
          "type": [
            "number",
            "null"
          ]
        },
        "rerank_rank": {
          "format": "uint",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "rerank_score": {
          "format": "float",
          "type": "number"
        },
        "state": {
          "$ref": "#/$defs/UnitState"
        },
        "subquery_ids": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "trust_level": {
          "$ref": "#/$defs/TrustLevel"
        },
        "unit_id": {
          "$ref": "#/$defs/UnitId"
        }
      },
      "required": [
        "unit_id",
        "channel",
        "channel_rank",
        "channel_score",
        "rerank_score",
        "trust_level",
        "state"
      ],
      "type": "object"
    },
    "RecallChannel": {
      "enum": [
        "exact",
        "lexical",
        "vector",
        "temporal",
        "edge",
        "exhaustive"
      ],
      "type": "string"
    },
    "RecallCitation": {
      "properties": {
        "episode_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/EpisodeId"
            },
            {
              "type": "null"
            }
          ]
        },
        "resource_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/ResourceId"
            },
            {
              "type": "null"
            }
          ]
        },
        "unit_id": {
          "$ref": "#/$defs/UnitId"
        }
      },
      "required": [
        "unit_id"
      ],
      "type": "object"
    },
    "RecallContextItem": {
      "properties": {
        "body": {
          "type": "string"
        },
        "citation_episode_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/EpisodeId"
            },
            {
              "type": "null"
            }
          ]
        },
        "citation_resource_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/ResourceId"
            },
            {
              "type": "null"
            }
          ]
        },
        "inclusion_reason": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/MemoryKind"
        },
        "suppression_labels": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "unit_id": {
          "$ref": "#/$defs/UnitId"
        }
      },
      "required": [
        "unit_id",
        "body",
        "kind",
        "inclusion_reason",
        "suppression_labels"
      ],
      "type": "object"
    },
    "RecallDropReason": {
      "enum": [
        "tenant",
        "scope",
        "privacy",
        "trust",
        "state",
        "stale",
        "budget",
        "duplicate",
        "rerank",
        "deleted",
        "invalidated",
        "unknown",
        "protected_category",
        "below_trust_floor",
        "irrelevant"
      ],
      "type": "string"
    },
    "RecallDroppedItem": {
      "properties": {
        "reason": {
          "$ref": "#/$defs/RecallDropReason"
        },
        "unit_id": {
          "$ref": "#/$defs/UnitId"
        }
      },
      "required": [
        "unit_id",
        "reason"
      ],
      "type": "object"
    },
    "RecallMode": {
      "enum": [
        "fast",
        "balanced",
        "exhaustive"
      ],
      "type": "string"
    },
    "RecallPolicyFilter": {
      "properties": {
        "detail": {
          "type": "string"
        },
        "reason": {
          "$ref": "#/$defs/RecallDropReason"
        }
      },
      "required": [
        "reason",
        "detail"
      ],
      "type": "object"
    },
    "ReflectStageFact": {
      "properties": {
        "detail": {
          "type": "string"
        },
        "stage": {
          "type": "string"
        }
      },
      "required": [
        "stage",
        "detail"
      ],
      "type": "object"
    },
    "ResourceId": {
      "format": "uuid",
      "type": "string"
    },
    "ScopeId": {
      "format": "uuid",
      "type": "string"
    },
    "TenantId": {
      "format": "uuid",
      "type": "string"
    },
    "TraceId": {
      "format": "uuid",
      "type": "string"
    },
    "TrustLevel": {
      "enum": [
        "trusted_user",
        "trusted_system",
        "verified_tool",
        "unverified_tool",
        "web_content",
        "agent_output",
        "imported_external",
        "quarantined"
      ],
      "type": "string"
    },
    "UnitId": {
      "format": "uuid",
      "type": "string"
    },
    "UnitState": {
      "enum": [
        "captured",
        "extracted",
        "candidate",
        "active",
        "superseded",
        "invalidated",
        "deleted",
        "quarantined",
        "expired",
        "validated",
        "retired"
      ],
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "abstention_signal": {
      "type": "boolean"
    },
    "actor_id": {
      "$ref": "#/$defs/ActorId"
    },
    "candidates": {
      "items": {
        "$ref": "#/$defs/RecallCandidateTrace"
      },
      "type": "array"
    },
    "channel_runs": {
      "items": {
        "$ref": "#/$defs/ReflectStageFact"
      },
      "type": "array"
    },
    "citations": {
      "items": {
        "$ref": "#/$defs/RecallCitation"
      },
      "type": "array"
    },
    "consolidation_lag_ms": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "context_items": {
      "items": {
        "$ref": "#/$defs/RecallContextItem"
      },
      "type": "array"
    },
    "cost_micros": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "decay_model_id": {
      "default": "",
      "type": "string"
    },
    "decomposition_reason": {
      "type": "string"
    },
    "dropped_items": {
      "items": {
        "$ref": "#/$defs/RecallDroppedItem"
      },
      "type": "array"
    },
    "engine_version": {
      "type": "string"
    },
    "escalation_reason": {
      "type": "string"
    },
    "feature_flags": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "filter_selectivity": {
      "format": "float",
      "type": [
        "number",
        "null"
      ]
    },
    "id": {
      "$ref": "#/$defs/TraceId"
    },
    "iterative_scan_depth": {
      "format": "uint32",
      "minimum": 0,
      "type": [
        "integer",
        "null"
      ]
    },
    "l4_gathered_evidence_ids": {
      "default": [],
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "l4_sandbox_id": {
      "default": null,
      "type": [
        "string",
        "null"
      ]
    },
    "latency_ms": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "mode_executed": {
      "$ref": "#/$defs/RecallMode"
    },
    "mode_requested": {
      "$ref": "#/$defs/RecallMode"
    },
    "policy_filters": {
      "items": {
        "$ref": "#/$defs/RecallPolicyFilter"
      },
      "type": "array"
    },
    "procedure_ids": {
      "default": [],
      "items": {
        "$ref": "#/$defs/UnitId"
      },
      "type": "array"
    },
    "procedure_validation_states": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ProcedureTraceFact"
      },
      "type": "array"
    },
    "query_hash": {
      "type": "string"
    },
    "rerank_input_count": {
      "format": "uint",
      "minimum": 0,
      "type": "integer"
    },
    "rerank_overfetch_ratio": {
      "format": "float",
      "type": "number"
    },
    "reranker_id": {
      "type": "string"
    },
    "scope_id": {
      "$ref": "#/$defs/ScopeId"
    },
    "subquery_ids": {
      "default": [],
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "tenant_id": {
      "$ref": "#/$defs/TenantId"
    },
    "token_estimate": {
      "format": "uint",
      "minimum": 0,
      "type": "integer"
    },
    "weight_vector_id": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "tenant_id",
    "scope_id",
    "actor_id",
    "query_hash",
    "engine_version",
    "feature_flags",
    "channel_runs",
    "candidates",
    "policy_filters",
    "context_items",
    "dropped_items",
    "citations",
    "consolidation_lag_ms",
    "weight_vector_id",
    "mode_requested",
    "mode_executed",
    "escalation_reason",
    "reranker_id",
    "rerank_input_count",
    "rerank_overfetch_ratio",
    "decomposition_reason",
    "abstention_signal",
    "latency_ms",
    "token_estimate",
    "cost_micros"
  ],
  "title": "RetrievalTrace",
  "type": "object"
}

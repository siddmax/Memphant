{
  "$defs": {
    "ActorId": {
      "format": "uuid",
      "type": "string"
    },
    "AgentNodeId": {
      "format": "uuid",
      "type": "string"
    },
    "CrossRerankFailure": {
      "enum": [
        "none",
        "error",
        "empty",
        "invalid_score_count",
        "non_finite_score"
      ],
      "type": "string"
    },
    "CrossRerankTrace": {
      "properties": {
        "batch_size": {
          "format": "uint",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "candidate_count": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "candidate_limit": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "failure": {
          "$ref": "#/$defs/CrossRerankFailure"
        },
        "input_chars_max": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "input_chars_p50": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "input_chars_p95": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "max_length": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "model": {
          "type": "string"
        },
        "provider": {
          "type": "string"
        }
      },
      "required": [
        "provider",
        "model",
        "candidate_limit",
        "candidate_count",
        "max_length",
        "input_chars_p50",
        "input_chars_p95",
        "input_chars_max",
        "failure"
      ],
      "type": "object"
    },
    "DeepRecallLimits": {
      "properties": {
        "max_context_tokens": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "max_spend_micros": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "max_tool_iterations": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "wall_time_ms": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "wall_time_ms",
        "max_tool_iterations",
        "max_context_tokens",
        "max_spend_micros"
      ],
      "type": "object"
    },
    "DeepRecallStatus": {
      "enum": [
        "completed",
        "capped"
      ],
      "type": "string"
    },
    "DeepRecallStopReason": {
      "enum": [
        "completed",
        "wall_time",
        "tool_iterations",
        "context_tokens",
        "spend"
      ],
      "type": "string"
    },
    "DeepRecallSummary": {
      "properties": {
        "limits": {
          "$ref": "#/$defs/DeepRecallLimits"
        },
        "status": {
          "$ref": "#/$defs/DeepRecallStatus"
        },
        "stop_reason": {
          "$ref": "#/$defs/DeepRecallStopReason"
        },
        "usage": {
          "$ref": "#/$defs/DeepRecallUsage"
        }
      },
      "required": [
        "status",
        "stop_reason",
        "limits",
        "usage"
      ],
      "type": "object"
    },
    "DeepRecallUsage": {
      "properties": {
        "context_tokens": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "spend_micros": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "tool_iterations": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "wall_time_ms": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "wall_time_ms",
        "tool_iterations",
        "context_tokens",
        "spend_micros"
      ],
      "type": "object"
    },
    "DegradedRecallTraceItem": {
      "additionalProperties": false,
      "properties": {
        "body": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/MemoryKind"
        }
      },
      "required": [
        "body",
        "kind"
      ],
      "type": "object"
    },
    "EpisodeId": {
      "format": "uuid",
      "type": "string"
    },
    "MemoryKind": {
      "enum": [
        "episodic",
        "semantic",
        "procedural",
        "belief",
        "resource"
      ],
      "type": "string"
    },
    "ProcedureTraceFact": {
      "properties": {
        "safety_status": {
          "type": "string"
        },
        "signal_kind": {
          "type": "string"
        },
        "unit_id": {
          "$ref": "#/$defs/UnitId"
        },
        "validation_state": {
          "type": "string"
        }
      },
      "required": [
        "unit_id",
        "validation_state",
        "signal_kind",
        "safety_status"
      ],
      "type": "object"
    },
    "RecallCandidateTrace": {
      "properties": {
        "channel": {
          "$ref": "#/$defs/RecallChannel"
        },
        "channel_rank": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "channel_score": {
          "format": "float",
          "type": "number"
        },
        "decay_retrievability": {
          "default": 0.0,
          "format": "float",
          "type": "number"
        },
        "derived_by": {
          "type": "string"
        },
        "discard_reason": {
          "anyOf": [
            {
              "$ref": "#/$defs/RecallDropReason"
            },
            {
              "type": "null"
            }
          ]
        },
        "dsr_difficulty": {
          "default": null,
          "format": "float",
          "type": [
            "number",
            "null"
          ]
        },
        "dsr_reinforcement_count": {
          "default": 0,
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "dsr_stability_days": {
          "default": null,
          "format": "float",
          "type": [
            "number",
            "null"
          ]
        },
        "fused_rank": {
          "format": "uint",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "fused_score": {
          "format": "float",
          "type": [
            "number",
            "null"
          ]
        },
        "rerank_rank": {
          "format": "uint",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "rerank_score": {
          "format": "float",
          "type": "number"
        },
        "state": {
          "$ref": "#/$defs/UnitState"
        },
        "subquery_ids": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "transaction_from": {
          "type": [
            "string",
            "null"
          ]
        },
        "transaction_to": {
          "type": [
            "string",
            "null"
          ]
        },
        "trust_level": {
          "$ref": "#/$defs/TrustLevel"
        },
        "unit_id": {
          "$ref": "#/$defs/UnitId"
        },
        "valid_from": {
          "type": [
            "string",
            "null"
          ]
        },
        "valid_to": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "unit_id",
        "channel",
        "channel_rank",
        "channel_score",
        "derived_by",
        "rerank_score",
        "trust_level",
        "state"
      ],
      "type": "object"
    },
    "RecallChannel": {
      "enum": [
        "exact",
        "lexical",
        "vector",
        "temporal",
        "edge",
        "deep"
      ],
      "type": "string"
    },
    "RecallCitation": {
      "properties": {
        "derived_from_unit_ids": {
          "default": [],
          "items": {
            "$ref": "#/$defs/UnitId"
          },
          "type": "array"
        },
        "episode_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/EpisodeId"
            },
            {
              "type": "null"
            }
          ]
        },
        "resource_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/ResourceId"
            },
            {
              "type": "null"
            }
          ]
        },
        "unit_id": {
          "$ref": "#/$defs/UnitId"
        }
      },
      "required": [
        "unit_id"
      ],
      "type": "object"
    },
    "RecallContextItem": {
      "properties": {
        "body": {
          "type": "string"
        },
        "citation_episode_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/EpisodeId"
            },
            {
              "type": "null"
            }
          ]
        },
        "citation_resource_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/ResourceId"
            },
            {
              "type": "null"
            }
          ]
        },
        "derived_by": {
          "type": "string"
        },
        "derived_from_unit_ids": {
          "default": [],
          "items": {
            "$ref": "#/$defs/UnitId"
          },
          "type": "array"
        },
        "inclusion_reason": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/MemoryKind"
        },
        "suppression_labels": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "unit_id": {
          "$ref": "#/$defs/UnitId"
        }
      },
      "required": [
        "unit_id",
        "body",
        "kind",
        "derived_by",
        "inclusion_reason",
        "suppression_labels"
      ],
      "type": "object"
    },
    "RecallDegradationDiagnostic": {
      "additionalProperties": false,
      "properties": {
        "consolidation_lag_ms": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "items": {
          "items": {
            "$ref": "#/$defs/DegradedRecallTraceItem"
          },
          "type": "array"
        },
        "reason": {
          "$ref": "#/$defs/RecallDegradationReason"
        }
      },
      "required": [
        "reason",
        "consolidation_lag_ms",
        "items"
      ],
      "type": "object"
    },
    "RecallDegradationReason": {
      "enum": [
        "pending_reflection_read_your_own_writes"
      ],
      "type": "string"
    },
    "RecallDropReason": {
      "enum": [
        "tenant",
        "scope",
        "privacy",
        "trust",
        "state",
        "stale",
        "budget",
        "duplicate",
        "rerank",
        "deleted",
        "invalidated",
        "unknown",
        "protected_category",
        "below_trust_floor",
        "irrelevant"
      ],
      "type": "string"
    },
    "RecallDroppedItem": {
      "properties": {
        "reason": {
          "$ref": "#/$defs/RecallDropReason"
        },
        "unit_id": {
          "$ref": "#/$defs/UnitId"
        }
      },
      "required": [
        "unit_id",
        "reason"
      ],
      "type": "object"
    },
    "RecallMode": {
      "enum": [
        "fast",
        "balanced",
        "deep"
      ],
      "type": "string"
    },
    "RecallPolicyFilter": {
      "properties": {
        "detail": {
          "type": "string"
        },
        "reason": {
          "$ref": "#/$defs/RecallDropReason"
        }
      },
      "required": [
        "reason",
        "detail"
      ],
      "type": "object"
    },
    "RecallTime": {
      "properties": {
        "evaluated_at": {
          "type": "string"
        },
        "transaction_as_of": {
          "type": "string"
        },
        "valid_at": {
          "type": "string"
        }
      },
      "required": [
        "evaluated_at",
        "transaction_as_of",
        "valid_at"
      ],
      "type": "object"
    },
    "ReflectStageFact": {
      "properties": {
        "detail": {
          "type": "string"
        },
        "stage": {
          "type": "string"
        }
      },
      "required": [
        "stage",
        "detail"
      ],
      "type": "object"
    },
    "ResourceId": {
      "format": "uuid",
      "type": "string"
    },
    "ScopeId": {
      "format": "uuid",
      "type": "string"
    },
    "SubjectId": {
      "format": "uuid",
      "type": "string"
    },
    "TenantId": {
      "format": "uuid",
      "type": "string"
    },
    "TraceId": {
      "format": "uuid",
      "type": "string"
    },
    "TrustLevel": {
      "enum": [
        "trusted_user",
        "trusted_system",
        "verified_tool",
        "unverified_tool",
        "web_content",
        "agent_output",
        "imported_external",
        "quarantined"
      ],
      "type": "string"
    },
    "UnitId": {
      "format": "uuid",
      "type": "string"
    },
    "UnitState": {
      "enum": [
        "captured",
        "extracted",
        "candidate",
        "active",
        "superseded",
        "invalidated",
        "deleted",
        "quarantined",
        "expired",
        "validated",
        "retired"
      ],
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "abstention_signal": {
      "type": "boolean"
    },
    "actor_id": {
      "$ref": "#/$defs/ActorId"
    },
    "agent_node_id": {
      "$ref": "#/$defs/AgentNodeId"
    },
    "candidates": {
      "items": {
        "$ref": "#/$defs/RecallCandidateTrace"
      },
      "type": "array"
    },
    "channel_runs": {
      "items": {
        "$ref": "#/$defs/ReflectStageFact"
      },
      "type": "array"
    },
    "citations": {
      "items": {
        "$ref": "#/$defs/RecallCitation"
      },
      "type": "array"
    },
    "consolidation_lag_ms": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "context_items": {
      "items": {
        "$ref": "#/$defs/RecallContextItem"
      },
      "type": "array"
    },
    "cost_micros": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "cross_rerank": {
      "anyOf": [
        {
          "$ref": "#/$defs/CrossRerankTrace"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "cross_rerank_ms": {
      "default": 0,
      "description": "R1.5-T1: per-recall wall-clock (ms) spent inside the W8 cross-encoder\nrerank stage ([`crate::CrossReranker`], distinct from the retired\nheuristic `reranker_id`/`rerank_input_count`/`rerank_overfetch_ratio`\nfields below). `0` when no cross-reranker is installed on the service\n(the default) or the candidate pool was empty — a legitimate \"not\nrun\" value, not a sentinel. `#[serde(default)]` so traces recorded\nbefore this field existed still deserialize.",
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "data_subject_id": {
      "$ref": "#/$defs/SubjectId"
    },
    "decay_model_id": {
      "default": "",
      "type": "string"
    },
    "decomposition_reason": {
      "type": "string"
    },
    "deep": {
      "anyOf": [
        {
          "$ref": "#/$defs/DeepRecallSummary"
        },
        {
          "type": "null"
        }
      ]
    },
    "degradation": {
      "anyOf": [
        {
          "$ref": "#/$defs/RecallDegradationDiagnostic"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "dropped_items": {
      "items": {
        "$ref": "#/$defs/RecallDroppedItem"
      },
      "type": "array"
    },
    "engine_version": {
      "type": "string"
    },
    "escalation_reason": {
      "type": "string"
    },
    "feature_flags": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "filter_selectivity": {
      "format": "float",
      "type": [
        "number",
        "null"
      ]
    },
    "id": {
      "$ref": "#/$defs/TraceId"
    },
    "iterative_scan_depth": {
      "format": "uint32",
      "minimum": 0,
      "type": [
        "integer",
        "null"
      ]
    },
    "l4_config_hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "l4_gathered_evidence_ids": {
      "default": [],
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "l4_model": {
      "type": [
        "string",
        "null"
      ]
    },
    "l4_prompt_hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "l4_provider": {
      "type": [
        "string",
        "null"
      ]
    },
    "l4_sandbox_id": {
      "default": null,
      "type": [
        "string",
        "null"
      ]
    },
    "l4_workspace_manifest_sha256": {
      "type": [
        "string",
        "null"
      ]
    },
    "latency_ms": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "learned_rerank_training_set_id": {
      "default": null,
      "type": [
        "string",
        "null"
      ]
    },
    "mode_executed": {
      "$ref": "#/$defs/RecallMode"
    },
    "mode_requested": {
      "$ref": "#/$defs/RecallMode"
    },
    "policy_filters": {
      "items": {
        "$ref": "#/$defs/RecallPolicyFilter"
      },
      "type": "array"
    },
    "policy_revision": {
      "type": "string"
    },
    "procedure_ids": {
      "default": [],
      "items": {
        "$ref": "#/$defs/UnitId"
      },
      "type": "array"
    },
    "procedure_validation_states": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ProcedureTraceFact"
      },
      "type": "array"
    },
    "query_hash": {
      "type": "string"
    },
    "recall_pool_depth": {
      "default": 0,
      "description": "R1.5-T0: the `recall_pool_depth` in effect for this recall — the ONE\nknob the vector/rerank/packing-scan internal fan-out derived from\n(never from `k`). Recorded per-trace so latency attribution stays\nobservable across deployments that override\n`MEMPHANT_RECALL_POOL_DEPTH`. `#[serde(default)]` so traces recorded\nbefore this field existed still deserialize (as `0`, a visible \"not\nrecorded\" sentinel — pool depth is never legitimately 0).",
      "format": "uint32",
      "minimum": 0,
      "type": "integer"
    },
    "recall_time": {
      "$ref": "#/$defs/RecallTime"
    },
    "rerank_input_count": {
      "format": "uint",
      "minimum": 0,
      "type": "integer"
    },
    "rerank_overfetch_ratio": {
      "format": "float",
      "type": "number"
    },
    "reranker_id": {
      "type": "string"
    },
    "scope_id": {
      "$ref": "#/$defs/ScopeId"
    },
    "subject_generation": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "subquery_ids": {
      "default": [],
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "tenant_id": {
      "$ref": "#/$defs/TenantId"
    },
    "token_estimate": {
      "format": "uint",
      "minimum": 0,
      "type": "integer"
    },
    "weight_vector_id": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "tenant_id",
    "data_subject_id",
    "scope_id",
    "actor_id",
    "agent_node_id",
    "subject_generation",
    "policy_revision",
    "query_hash",
    "engine_version",
    "feature_flags",
    "channel_runs",
    "candidates",
    "policy_filters",
    "context_items",
    "dropped_items",
    "citations",
    "consolidation_lag_ms",
    "weight_vector_id",
    "mode_requested",
    "mode_executed",
    "escalation_reason",
    "reranker_id",
    "rerank_input_count",
    "rerank_overfetch_ratio",
    "decomposition_reason",
    "abstention_signal",
    "latency_ms",
    "token_estimate",
    "cost_micros",
    "recall_time"
  ],
  "title": "RetrievalTrace",
  "type": "object"
}

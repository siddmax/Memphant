# Rust build artifacts
/target/
/spikes/rust-retain/target/
**/*.rs.bk

# Python caches and local environments
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# Web dependencies and browser test artifacts
node_modules/
playwright-report/
test-results/

# Local secrets and machine-specific config
.env
.env.*
!.env.example
*.local

# Local Codex state; keep the repo-link manifest trackable.
.codex/feature-flow/

# OS and editor state
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Logs and transient outputs
*.log
tmp/
temp/
# Ignore fetched benchmark datasets, but keep the mined syndai-gate golden
# set + lock (small, version-pinned; the W10 gate scores against them).
benchmarks/data/*
!benchmarks/data/syndai_docs_golden.jsonl
!benchmarks/data/syndai_docs_golden.lock.json
!benchmarks/data/syndai_docs_golden_v2.jsonl
!benchmarks/data/syndai_docs_golden_v2.lock.json
.fastembed_cache/
# Reader-lane evidence packs embed raw LongMemEval session text (the raw
# dataset stays out of the repo); the scored reader-*.json reports are committed.
docs/build-log/artifacts/*/reader-evidence-*.jsonl
docs/build-log/artifacts/*/reader-cache/
# Syndai-gate lane: evidence packs embed raw retrieved doc bodies and the miner
# cache embeds full corpus sections; scored reports + compare verdict are committed.
docs/build-log/artifacts/syndai-gate/*_evidence.jsonl
docs/build-log/artifacts/syndai-gate/miner-cache/
docs/build-log/artifacts/*/ev-*.jsonl
# R0 embedder bakeoff (docs + chat lanes): evidence packs embed raw retrieved
# doc bodies / raw corpus text; the shared reader cache is regenerable.
# provenance.json / lme-*.json / reader-*.json score reports are committed.
docs/build-log/artifacts/r0-embedder/**/evidence.jsonl
docs/build-log/artifacts/r0-embedder/**/ev-*.jsonl
docs/build-log/artifacts/r0-embedder/reader-cache/

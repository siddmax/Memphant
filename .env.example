# Local development only. Do not copy production credentials into this file.
DATABASE_URL=postgres://memphant:memphant@localhost:5432/memphant
MEMPHANT_BIND=127.0.0.1:3000
MEMPHANT_PROVIDER=plain-postgres
MEMPHANT_DB_SCHEMA=memphant
MEMPHANT_LOG=info
MEMPHANT_STRUCTURED_STATE_PROMPT_PATH=config/structured-state-v1.txt

# Explicit remote-model egress for Deep recall. Disabled by default.
# MEMPHANT_DEEP=on
# OPENROUTER_API_KEY=
# MEMPHANT_DEEP_MODEL=anthropic/claude-sonnet-5
# MEMPHANT_DEEP_PROMPT_PATH=config/deep-recall-v1.txt
# MEMPHANT_DEEP_PROVIDERS=azure
# MEMPHANT_DEEP_INPUT_PRICE_MICROS_PER_MILLION=2000000
# MEMPHANT_DEEP_OUTPUT_PRICE_MICROS_PER_MILLION=10000000
# MEMPHANT_DEEP_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

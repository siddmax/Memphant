# Local development only. Do not copy production credentials into this file.
DATABASE_URL=postgres://memphant:memphant@localhost:5432/memphant
MEMPHANT_BIND=127.0.0.1:3000
MEMPHANT_PROVIDER=plain-postgres
MEMPHANT_DB_SCHEMA=memphant
MEMPHANT_LOG=info
MEMPHANT_STRUCTURED_STATE_PROMPT_PATH=config/structured-state-v1.txt

# Explicit remote-model egress for Deep recall. Disabled by default.
# MEMPHANT_DEEP=on
# OPENROUTER_API_KEY=
# MEMPHANT_DEEP_MODEL=anthropic/claude-sonnet-5-20260630
# MEMPHANT_DEEP_RESPONSE_MODEL=anthropic/claude-sonnet-5
# MEMPHANT_DEEP_PROMPT_PATH=config/deep-recall-v1.txt
# MEMPHANT_DEEP_PROVIDERS=azure
# MEMPHANT_DEEP_INPUT_PRICE_MICROS_PER_MILLION=2000000
# MEMPHANT_DEEP_OUTPUT_PRICE_MICROS_PER_MILLION=10000000
# MEMPHANT_DEEP_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ---------------------------------------------------------------------------
# W8 cross-encoder rerank — RECOMMENDED PRODUCTION CONFIG (P1 bench 2026-07-22).
# Off by default (self-host / no-key deployments stay zero-cost). Enable per tier.
# Evidence: docs/build-log/artifacts/p1-retrieval-bench/RESULTS.md (n=72 adversarial
# LME-S). Rerank is the highest-ROI stage: +0.111 recall@5 / +0.223 MRR over none.
# NOTE: promoted on the retrieval-frontier screen; the paid reader-QA gate the STATUS
# ledger normally requires for a default flip was OWNER-WAIVED (2026-07-22). Both
# tiers are one env var from OFF if production disagrees — reversible by design.
#
# FREE / self-host tier — local MiniLM-L6-int8 (Apache, CPU, $0 recurring):
#   recall@5 0.889 / MRR 0.804. body granularity (won the live n=20 A/B, simpler +
#   faster than chunk); the chunk+cap path is available for deep-buried corpora.
#   Needs the MiniLM ONNX + tokenizer locally (download Xenova/ms-marco-MiniLM-L-6-v2).
# MEMPHANT_CROSS_RERANK=on
# MEMPHANT_RERANKER=byo
# MEMPHANT_RERANK_BYO_DIR=/path/to/ms-marco-MiniLM-L-6-v2   # model_quantized.onnx + tokenizer.json
# MEMPHANT_RERANK_GRANULARITY=body                          # default; 'chunk' uses the sub-split cap
#
# PAID tier — Voyage rerank-2.5 (accuracy-max: recall@5 0.944 / MRR 0.858 / 705ms,
#   ~$4.50/1k queries). Handles long docs natively (no chunk cap needed). Cost-value
#   alternative: Cohere v4.0-pro (0.944 / 0.852, ~$2.50/1k) via MEMPHANT_RERANKER=
#   cohere-rerank-3.5 + MEMPHANT_COHERE_MODEL=rerank-v4.0-pro.
# MEMPHANT_CROSS_RERANK=on
# MEMPHANT_RERANKER=voyage-rerank-2.5
# VOYAGE_API_KEY=
# MEMPHANT_RERANK_TIMEOUT_MS=1500                           # per-query ceiling; 0 = unbounded

# Fusion: tuned convex combination beat RRF on the P1 bench (recall@5 0.847 vs 0.833);
# adopting it is a retrieval-side change tracked separately (no new recurring cost).
